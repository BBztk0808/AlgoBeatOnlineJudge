# Secrets
# 这些是 SYZOJ 服务运行所需的密钥。请使用以下命令生成 3 个长随机字符串替换占位符:
#   openssl rand -hex 32
#
# 每个字段必须是不同的随机值。生成后保存为 env-app（去掉 .example 后缀）。
# 注意:env-app 文件不要提交到任何公开仓库。

SYZOJ_WEB_SECRET_SESSION=请替换为 64 位随机字符串
SYZOJ_WEB_SECRET_JUDGE=请替换为 64 位随机字符串
SYZOJ_WEB_SECRET_EMAIL=请替换为 64 位随机字符串

# 站点外部访问地址(用于邮件验证链接;本地可留空自动使用请求 Host)
SYZOJ_WEB_PUBLIC_BASE_URL=

# 调试开关:设为 1 才输出评测进度调试日志
SYZOJ_DEBUG_JUDGE_PROGRESS=0

# SMTP 邮件发送配置(用于邮箱验证)
SYZOJ_WEB_SMTP_HOST=smtp.zoho.com.cn
SYZOJ_WEB_SMTP_PORT=465
SYZOJ_WEB_SMTP_USER=你的发件邮箱地址
SYZOJ_WEB_SMTP_PASS=你的应用专用密码(不是登录密码)
SYZOJ_WEB_SMTP_FROM_NAME=AlgoBeat Online Judge
