<% this.title = isNew ? '新建题单' : '编辑题单' %>
<% include header %>

<div class="padding">
  <div class="ab-toolbar" style="margin-bottom: 18px;">
    <h2 style="margin: 0;"><i class="tasks icon"></i> <%= isNew ? '新建题单' : '编辑题单' %></h2>
    <% if (!isNew) { %>
      <a class="ui button" href="<%= syzoj.utils.makeUrl(['problemset', set.id]) %>">
        <i class="eye icon"></i> 查看题单
      </a>
    <% } %>
  </div>

  <form class="ui form" method="post" action="<%= isNew ? syzoj.utils.makeUrl(['problemset', 'new']) : syzoj.utils.makeUrl(['problemset', set.id, 'edit']) %>">
    <div class="field">
      <label>标题</label>
      <input type="text" name="title" maxlength="80" value="<%= set.title || '' %>" placeholder="例如：动态规划入门训练" required>
    </div>

    <div class="field">
      <label>可见性</label>
      <div class="ui selection <% if (!canPublishPublic) { %>disabled <% } %>dropdown">
        <input type="hidden" name="visibility" value="<%= set.visibility || 'private' %>">
        <i class="dropdown icon"></i>
        <div class="default text">选择可见性</div>
        <div class="menu">
          <div class="item" data-value="private"><i class="lock icon"></i>私有</div>
          <% if (canPublishPublic) { %>
            <div class="item" data-value="public"><i class="globe icon"></i>公开</div>
          <% } %>
        </div>
      </div>
      <% if (!canPublishPublic) { %>
        <div style="color: #888; margin-top: 8px;">
          普通用户只能创建私有题单。公开题单需要题单管理权限。
        </div>
      <% } %>
    </div>

    <div class="field">
      <label>介绍</label>
      <textarea name="description" rows="6" maxlength="5000" placeholder="支持 Markdown，可写训练目标、前置知识、推荐顺序等。"><%= set.description || '' %></textarea>
    </div>

    <div class="field">
      <label>题目列表</label>
      <textarea name="items_text" rows="14" placeholder="每行一个题号，可在题号后写备注。例如：&#10;1001 二分答案&#10;1002 树形 DP"><%= set.itemsText || '' %></textarea>
      <div style="color: #888; margin-top: 8px;">
        最多 300 题。格式：<code>题号 可选备注</code>，重复题号会自动去重。
      </div>
    </div>

    <button class="ui primary button" type="submit">
      <i class="save icon"></i> 保存题单
    </button>
    <a class="ui button" href="<%= syzoj.utils.makeUrl(['problemsets']) %>">取消</a>
  </form>

  <% if (!isNew) { %>
    <div class="ui divider"></div>
    <form method="post" action="<%= syzoj.utils.makeUrl(['problemset', set.id, 'delete']) %>"
          onsubmit="return confirm('确认删除此题单？题单中的题目不会被删除。');">
      <button class="ui red button" type="submit">
        <i class="trash icon"></i> 删除题单
      </button>
    </form>
  <% } %>
</div>

<script>
$(function () {
  $('.ui.dropdown').dropdown();
});
</script>

<% include footer %>
